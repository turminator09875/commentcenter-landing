{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "og-image.svg", "use": "@vercel/static" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ],
  "routes": [
    { "src": "/privacy", "status": 301, "headers": { "Location": "https://app.commentcenter.nl/privacy" } },
    { "src": "/privacy.html", "status": 301, "headers": { "Location": "https://app.commentcenter.nl/privacy" } },
    { "src": "/terms", "status": 301, "headers": { "Location": "https://app.commentcenter.nl/terms" } },
    { "src": "/terms.html", "status": 301, "headers": { "Location": "https://app.commentcenter.nl/terms" } },
    { "src": "/data-deletion", "status": 301, "headers": { "Location": "https://app.commentcenter.nl/data-deletion" } },
    { "src": "/bewijs", "status": 301, "headers": { "Location": "/#pricing" } },
    { "src": "/og-image.svg", "dest": "/og-image.svg" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
